# GPT-compatible LLM config
#
# Set these when you want /api/questions/extract and
# /api/attempts/:id/llm-score to call a real model. When they are absent,
# those routes return LLM_NOT_CONFIGURED 400 and the manual paste routes
# (/api/questions/import, /api/attempts/:id/score) keep working.
#
# Supported styles:
# - responses         : OpenAI Responses-style API
# - chat_completions  : OpenAI Chat Completions-style API
#
# Examples:
# - OpenAI official:
#   LLM_BASE_URL=https://api.openai.com/v1
#   # LLM_MODEL optional, defaults to gpt-5.2
#   # LLM_API_STYLE optional, defaults to responses
#
# - DeepSeek:
#   LLM_BASE_URL=https://api.deepseek.com
#   # LLM_MODEL optional, defaults to deepseek-chat
#   # LLM_API_STYLE optional, defaults to chat_completions
#
# - GPT-compatible third-party:
#   LLM_BASE_URL=https://www.dogapi.cc/v1
#   # LLM_MODEL optional, defaults to gpt-5.2
#   # LLM_API_STYLE optional, defaults to responses
#
# - DashScope / 阿里云百炼:
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_MODEL=qwen3.6-plus
#   LLM_API_STYLE=chat_completions
#
# Never commit a real key. This file is the example template only.

# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=
# LLM_API_STYLE=
# LLM_REASONING_EFFORT=high

# NOWCODER_ARTICLE_TTL_DAYS=14
#
# How long source=nowcoder ArticleRecord rows are kept on disk. Pruned at the
# start of every /api/sources/nowcoder/fetch call. source=manual records are
# never pruned. Default 14 days; raise/lower to taste.
